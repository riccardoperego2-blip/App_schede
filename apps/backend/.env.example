# =============================================================================
# Schede backend — environment template (copy to `.env` or `.env.local`)
# =============================================================================
# Validated at startup by `src/core/config/server-env.ts` (Zod + fail-fast).
# Full documentation: ../../ENV_SETUP.md
# =============================================================================

# --- runtime ---
NODE_ENV=development
PORT=3000
# Leave empty so routes are `/v1/...`. Set to `api` if you serve behind `/api`.
API_PREFIX=

# --- database (required) ---
# Postgres connection string for `pg.Pool` (PgUnitOfWork).
# Local Supabase CLI: copy "DB URL" from `supabase status`.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Pool size (optional, 1–200). Also consumed via validated AppConfig — not raw process.env.
PG_POOL_MAX=10

# --- Supabase — server only (required) ---
# Project URL (same as in Supabase dashboard).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# service_role JWT — NEVER expose to mobile, never prefix with EXPO_PUBLIC_.
# Project Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# --- CORS ---
# Comma-separated browser origins allowed to call the API with credentials.
# Development: leave empty → any browser origin (Expo web, LAN).
# Production: optional. Empty = no browser origin whitelisted; native apps (no Origin) still work.
# Add URLs for Expo Web or admin dashboards, e.g. https://your-app.vercel.app
CORS_ORIGINS=
