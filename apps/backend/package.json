{
  "name": "@schede/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prestart": "pnpm --filter \"./../../packages/*\" -r build",
    "prestart:dev": "pnpm --filter \"./../../packages/*\" -r build",
    "prebuild": "pnpm --filter \"./../../packages/*\" -r build",
    "start": "nest start",
    "start:prod": "node dist/apps/backend/src/main.js",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/event-emitter": "^2.1.1",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/throttler": "^6.2.1",
    "@schede/exercise-selection": "workspace:*",
    "@schede/workout-execution": "workspace:*",
    "@schede/workout-generation": "workspace:*",
    "@supabase/supabase-js": "^2.47.10",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.0.0",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "~5.6.3"
  }
}
