# =============================================================================
# Schede mobile (Expo) — public environment template
# =============================================================================
# Copy to `.env` or `.env.local`. Only `EXPO_PUBLIC_*` keys are inlined in the JS bundle.
# Validated at startup by `src/lib/env.ts` (Zod + fail-fast).
# Full documentation: ../../ENV_SETUP.md
#
# NEVER put `SUPABASE_SERVICE_ROLE_KEY` here — use the anon key only.
# =============================================================================

# --- Backend API ---
# In __DEV__, if the URL uses localhost/127.0.0.1, the app replaces the host with
# the LAN IP of the PC running Metro (from Expo Go `debuggerHost` or `SourceCode.scriptURL`).
# Physical iPhone + Expo Go: keep http://localhost:PORT here or omit and rely on app.json fallback.
# Production fallback (when no env is set): https://appschede-production.up.railway.app
# Optional: force backend port when building the LAN fallback (default 3000).
# EXPO_PUBLIC_API_PORT=3000
# Optional: disable LAN rewrite (use only when debugging URL logic).
# EXPO_PUBLIC_DISABLE_LAN_API_FALLBACK=1
EXPO_PUBLIC_API_URL=http://localhost:3000
# Legacy alias — same meaning as EXPO_PUBLIC_API_URL:
# EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# --- Supabase — public keys only (required unless set in app.json extra) ---
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Anon (public) key from Supabase Studio → Project Settings → API → anon public
EXPO_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key

# --- Optional kill-switches (see src/lib/feature-flags/flags.ts) ---
# OTA defaults live in app.json → expo.extra.flags. Env wins at build time.
# EXPO_PUBLIC_FLAG_ANALYTICS_ENABLED=true
# EXPO_PUBLIC_FLAG_REALTIME_ENABLED=true
# EXPO_PUBLIC_FLAG_OFFLINE_QUEUE_ENABLED=true
# EXPO_PUBLIC_FLAG_CIRCUIT_BREAKER_ENABLED=true
# EXPO_PUBLIC_FLAG_KEEP_AWAKE_DEFAULT=true

# --- Forbidden (do not add — the app refuses to boot if set) ---
# EXPO_PUBLIC_SUPABASE_SERVICE_ROLE_KEY=
