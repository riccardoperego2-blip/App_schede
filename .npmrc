# Expo / React Native expects a flat node_modules layout. With pnpm's
# default strict layout, Metro can fail to resolve transitive deps
# (e.g. plugin packages declared by Expo modules). `node-linker=hoisted`
# produces an npm-compatible flat tree under the workspace root while
# keeping pnpm's symlinked workspace packages.
node-linker=hoisted

# Auto-install peer deps for the engines + UI libs in this project.
auto-install-peers=true

# Strict-peer-deps off because Expo / NestJS sub-deps occasionally
# pin slightly different ranges; pnpm would otherwise refuse install.
strict-peer-dependencies=false
